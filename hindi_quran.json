  "data": {
    "surahs": [
      {
        "id": 1,
        "englishName": "Al-Faatiha",
        "name": "سُورَةُ الْفَاتِحَةِ",
        "ayahs": [
          { "numberInSurah": 1, "text": "अल्लाह के नाम से, जो अत्यंत कृपाशील और दयावान है।" },
          { "numberInSurah": 2, "text": "सब प्रकार की प्रशंसा अल्लाह ही के लिए है, जो सारे संसार का रब है," },
          { "numberInSurah": 3, "text": "जो अत्यंत कृपाशील और दयावान है," },
          { "numberInSurah": 4, "text": "बदले के दिन (क़ियामत) का मालिक है।" },
          { "numberInSurah": 5, "text": "हम केवल तेरी ही इबादत करते हैं और केवल तुझसे ही मदद चाहते हैं।" },
          { "numberInSurah": 6, "text": "हमें सीधे मार्ग पर चला," },
          { "numberInSurah": 7, "text": "उन लोगों के मार्ग पर जो तेरे कृपापात्र हुए, जो न कोपभाजन हुए और न मार्गभ्रष्ट।" }
        ]
      },
      {
        "id": 2,
        "englishName": "Al-Baqara",
        "name": "سُورَةُ الْबَقَرَةِ",
        "ayahs": [
          { "numberInSurah": 1, "text": "अलिफ़-लाम-मीम।" },
          { "numberInSurah": 2, "text": "यह वह किताब है जिसमें कोई संदेह नहीं; मार्गदर्शन है डर रखने वालों के लिए," },
          { "numberInSurah": 3, "text": "जो परोक्ष (बिन देखे) पर ईमान लाते हैं, नमाज़ क़ायम करते हैं, और जो कुछ हमने उन्हें दिया है, उसमें से ख़र्च करते हैं।" }
        ]
      },
      {
        "id": 36,
        "englishName": "Yaseen",
        "name": "سُورَةُ يٰسٓ",
        "ayahs": [
          { "numberInSurah": 1, "text": "या-सीन।" },
          { "numberInSurah": 2, "text": "हिकमत (बुद्धिमत्ता) वाले क़ुरआन की क़सम!" },
          { "numberInSurah": 3, "text": "निस्संदेह, आप रसूलों में से हैं," },
          { "numberInSurah": 4, "text": "एक सीधे मार्ग पर।" }
        ]
      },
      {
        "id": 112,
        "englishName": "Al-Ikhlaas",
        "name": "سُورَةُ الإِخْلَاصِ",
        "ayahs": [
          { "numberInSurah": 1, "text": "कहो, 'वह अल्लाह एक है,'" },
          { "numberInSurah": 2, "text": "अल्लाह बेनियाज़ (परम स्वतंत्र) है।" },
          { "numberInSurah": 3, "text": "न उसकी कोई संतान है और न वह किसी की संतान है," },
          { "numberInSurah": 4, "text": "और न कोई उसके बराबर का है।'" }
        ]
      }
    ]
  }
